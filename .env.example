PORT=8080
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=phoenix_inventory
EVENT_SERVICE_URL=http://localhost:3000
EVENT_SERVICE_TIMEOUT_MS=3000
ENVIRONMENT=development
SERVICE_NAME=ticket-inventory-service
LOG_LEVEL=info
HOLD_TTL_MINUTES=15

# Shared with User Service (HS256). Required unless AUTH_DISABLED is used in development/test only.
JWT_SECRET=

# development|test only: skip JWT validation (never enable in production).
AUTH_DISABLED=false

# JSON map: service id (JWT sub when typ=service) -> allowed permission names.
# Example: {"booking-service":["RESERVE_TICKET"],"event-service":["CREATE_TICKET_TYPE","UPDATE_TICKET_INVENTORY","VIEW_TICKET_INVENTORY"]}
SERVICE_REGISTRY=
